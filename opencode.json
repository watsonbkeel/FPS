{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/*.md"
  ],
  "permission": {
    "edit": "ask",
    "write": "ask",
    "bash": "ask",
    "delete": "ask"
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "__pycache__/**",
      ".pytest_cache/**",
      "playwright-report/**",
      "test-results/**"
    ]
  },
  "autoupdate": false
}
